{
  "name": "@snomiao/beancount-formatter",
  "description": "Beancount file formatter library wrapping vscode-beancount-formatter",
  "keywords": [
    "beancount",
    "formatter",
    "plaintext-accounting",
    "finance"
  ],
  "homepage": "https://github.com/snomiao/beancount-formatter#readme",
  "bugs": {
    "url": "https://github.com/snomiao/beancount-formatter/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/snomiao/beancount-formatter.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.1.0",
  "author": "snomiao <snomiao@gmail.com>",
  "type": "module",
  "exports": {
    "import": "./dist/index.js",
    "types": "./index.ts"
  },
  "module": "index.ts",
  "types": "./index.ts",
  "files": [
    "*.ts",
    "dist"
  ],
  "scripts": {
    "prepare": "git submodule update --init",
    "build": "bun build index.ts --outdir=dist && bun run build:umd",
    "build:umd": "bunx rollup dist/index.js --file dist/index.umd.js --format umd --name beancountFormatter",
    "lint": "oxlint .",
    "lint:fix": "oxlint --fix .",
    "fmt": "oxfmt '**/*.{ts,tsx,js,jsx,mjs,cjs}'",
    "typecheck": "bunx tsgo --noEmit",
    "prerelease": "bun run build",
    "release": "bunx semantic-release",
    "test": "bun test"
  },
  "devDependencies": {
    "@semantic-release/git": "latest",
    "@semantic-release/github": "latest",
    "@typescript/native-preview": "latest",
    "@types/bun": "^1.3.12",
    "oxlint": "latest",
    "semantic-release": "latest"
  },
  "peerDependencies": {
    "typescript": "^5.5.3"
  }
}
