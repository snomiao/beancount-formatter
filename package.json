{
  "name": "@snomiao/beancount-formatter",
  "publishConfig": {
    "access": "public"
  },
  "version": "0.0.1",
  "author": "snomiao <snomiao@gmail.com>",
  "type": "module",
  "exports": {
    "import": "./dist/index.js",
    "types": "./index.ts"
  },
  "module": "index.ts",
  "types": "./index.ts",
  "files": [
    "*.ts",
    "dist"
  ],
  "scripts": {
    "build": "bun build index.ts --outdir=dist && bun build:umd",
    "build:umd": "bunx rollup dist/index.js --file dist/index.umd.js --format umd --name beancountFormatter",
    "prerelease": "bun run build && echo bypass tests",
    "release": "bunx standard-version && git push --follow-tags && npm publish",
    "test": "bun test"
  },
  "devDependencies": {
    "@types/bun": "^1.1.6",
    "@types/jest": "^29.5.12"
  },
  "peerDependencies": {
    "typescript": "^5.5.3"
  }
}
